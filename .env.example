OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL_NAME=gpt-4o-mini

# Optional NVIDIA model support (not required for core flow)
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_MODEL_NAME=meta/llama-3.1-8b-instruct

# LinkedIn agent defaults
LINKEDIN_DEFAULT_LOCATION=Remote
LINKEDIN_DEFAULT_NUM_JOBS=20
LINKEDIN_MEMORY_PATH=linkedin_memory.json
LINKEDIN_CHROMA_DIR=chroma_db
LINKEDIN_MAX_JOB_AGE_DAYS=3
LINKEDIN_DEFAULT_EXPERIENCE_LEVEL=any
LINKEDIN_PAGE_TIMEOUT_SECONDS=60
AGENT_DEFAULT_TOP_K=5
LI_AT_COOKIE=your_li_at_cookie_value_here
# Authenticated LinkedIn session (recommended for reliable scraping).
# If set, the scraper uses your session cookie instead of anonymous mode.
# See README "Authenticated scraping" for how to get this value.
# LI_AT_COOKIE=your_li_at_cookie_value_here

# When true (default), if live scraping returns no jobs or fails,
# the agent will fall back to a small set of local sample jobs
# so the end-to-end workflow still runs.
LINKEDIN_USE_SAMPLE_JOBS_IF_EMPTY=true

# Optional search / tools (not currently required but useful for extensions)
SERPAPI_API_KEY=your_serpapi_key_here
TAVILY_API_KEY=your_tavily_key_here

